# Include the Rust sidecar crate sources in the sdist so source-only
# installs can rebuild the native backend via ``setup.py``. Wheels do
# not need these files — they ship the pre-built binary under
# ``src/lingtai/bin/`` via ``[tool.setuptools.package-data]``.
graft crates/lingtai-search-sidecar/src
include crates/lingtai-search-sidecar/Cargo.toml
include crates/lingtai-search-sidecar/Cargo.lock
include crates/lingtai-search-sidecar/README.md

# Exclude transient cargo build artifacts so they don't bloat the sdist.
prune crates/lingtai-search-sidecar/target

# The wheel-bundled binary at src/lingtai/bin/ is reproducible from the
# crate sources above — keep it out of the sdist so source releases stay
# source-only. setup.py rebuilds it when the sdist is unpacked and built
# into a wheel.
exclude src/lingtai/bin/*
exclude src/lingtai/bin/__init__.py
prune src/lingtai/bin

# Top-level packaging shim and license live at the repo root.
include setup.py
include MANIFEST.in
include LICENSE
include NOTICE
include README.md

# Include packaged prompt resources and the runtime guidance Markdown catalog in
# sdists. pyproject.toml owns wheel package-data globs; keep this connected so
# source releases carry the same prompt corpus. The `*.yaml` line carries the
# section-definition YAML under prompts/<section>/ into source releases too.
recursive-include src/lingtai/prompts *.md
recursive-include src/lingtai/prompts *.yaml

# Kernel i18n catalogs ship with the runtime; mirror the wheel package-data
# glob so source releases carry the same localized strings.
recursive-include src/lingtai/kernel/i18n *.json

# Consolidated tool packages ship data assets (i18n catalogs, per-tool JSON
# policy/data files, and manual trees). pyproject.toml owns the wheel
# package-data globs; mirror them here so source releases carry the same tool
# assets. ``graft`` pulls the manual trees (arbitrary file types) wholesale.
recursive-include src/lingtai/tools *.json
# Per-tool contracts (src/lingtai/tools/<tool>/CONTRACT.md) and the daemon extension
# contract (lingtai/tools/daemon/DAEMON_CONTRACT.md) — mirror the package-data globs
# in pyproject.toml so source releases carry the same tool contracts.
recursive-include src/lingtai/tools CONTRACT.md
recursive-include src/lingtai/tools DAEMON_CONTRACT.md
# Per-tool glossary resources — mirror the package-data globs in
# pyproject.toml so source releases carry the 54 files (exact filenames,
# not a wildcard, to prevent accidental inclusion of extra files).
recursive-include src/lingtai/tools glossary-en.md
recursive-include src/lingtai/tools glossary-zh.md
recursive-include src/lingtai/tools glossary-wen.md
graft src/lingtai/tools/email/manual
graft src/lingtai/tools/system/manual
graft src/lingtai/tools/psyche/manual
graft src/lingtai/tools/soul/manual
graft src/lingtai/tools/notification/manual
graft src/lingtai/tools/knowledge/manual
graft src/lingtai/tools/skills/manual
graft src/lingtai/tools/bash/manual
graft src/lingtai/tools/avatar/manual
graft src/lingtai/tools/daemon/manual
graft src/lingtai/tools/mcp/manual
