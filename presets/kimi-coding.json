{
  "name": "kimi-coding",
  "description": {
    "summary": "Kimi Code (Moonshot) — OpenAI-compatible, subscription-based, tool calling",
    "tier": "3"
  },
  "manifest": {
    "llm": {
      "provider": "kimi",
      "api_compat": "openai",
      "model": "kimi-for-coding",
      "base_url": "https://api.kimi.com/coding/v1",
      "api_key_env": "KIMI_CODE_API_KEY"
    },
    "capabilities": {
      "avatar": {},
      "bash": { "yolo": true },
      "codex": {},
      "daemon": {},
      "email": {},
      "file": {},
      "library": {},
      "psyche": {},
      "web_search": { "provider": "duckduckgo" }
    }
  }
}
